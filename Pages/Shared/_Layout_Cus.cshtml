<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizStudy</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/_Layout_Cus.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/CusDetail/homepage-cards.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/DALTWNC_QUIZ.styles.css" asp-append-version="true" />

</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom sticky-top">
            <div class="container">

                <a class="navbar-brand" asp-page="/Index">
                    <i class="fa-solid fa-brain me-2"></i>
                    <span class="brand-quiz">Quiz</span><span class="brand-study">Study</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <form asp-page="/Search" method="get" id="searchForm"
                          class="d-flex position-relative my-2 my-lg-0 mx-auto" style="width: 50%;">

                        <input type="search"
                               name="key"
                               id="searchBox"
                               class="form-control"
                               placeholder="Tìm kiếm bộ đề, môn học..."
                               autocomplete="off">

                        <button class="btn btn-primary ms-1" type="submit" id="searchButton"
                                style="background-color: #198754; border-color: #198754;">
                            <i class="fa-solid fa-search"></i>
                        </button>

                        <div class="list-group shadow-lg position-absolute w-100"
                             id="searchResults"
                             style="display: none; z-index: 1000; max-height: 400px; overflow-y: auto; top: 100%; margin-top: 8px;">
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("A"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" asp-page="/Admin/Home">
                                        <i class="fa-solid fa-user-shield me-1"></i> Trang Admin
                                    </a>
                                </li>
                            }

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-solid fa-user-circle me-1"></i>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownUser">
                                    <a class="dropdown-item"
                                       asp-page="/Customer/Profiles/Profile"
                                       asp-route-username="@User.Identity?.Name">
                                        Thông tin tài khoản
                                    </a>

                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-page="/Customer/Histories/History"
                                           asp-route-username="@User.Identity?.Name">
                                            Lịch sử làm bài
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item text-dange" asp-page="/Customer/Quiz_Result/Saved">Đề thi đã lưu</a>
                                    </li>

                                    <li><a class="dropdown-item text-danger" asp-page="/Account/Logout">Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-primary btn-sm px-3" asp-page="/Account/Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" asp-page="/Account/Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-main">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <a class="footer-brand d-flex align-items-center" asp-page="/Index">
                        <i class="fas fa-brain me-2"></i>
                        <span>QuizStudy</span>
                    </a>
                    <p class="mt-3 footer-description">
                        Hệ thống trắc nghiệm trực tuyến giúp bạn củng cố kiến thức mọi lúc mọi nơi.
                    </p>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li><a asp-page="/Index">Trang chủ</a></li>
                        <li><a asp-page="/Customer/Subjects/Index">Làm bài</a></li>
                        <li><a asp-page="/About">Giới thiệu</a></li>
                        <li><a asp-page="/Login">Đăng nhập</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h5>Hỗ trợ</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Câu hỏi thường gặp (FAQ)</a></li>
                        <li><a asp-page="/Privacy">Chính sách bảo mật</a></li>
                        <li><a href="#">Điều khoản dịch vụ</a></li>
                        <li><a asp-page="/Contact">Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h5>Theo dõi</h5>
                    <p class="footer-description">Kết nối với chúng tôi qua các mạng xã hội.</p>
                    <div class="social-icons">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                        <a href="#" title="Github"><i class="fab fa-github"></i></a>
                    </div>
                </div>

            </div>
        </div>
    </footer>

    <div class="footer-bottom">
        <div class="container">
            &copy; @DateTime.Now.Year - QuizSystem by QuizStudy. All rights reserved.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchForm = document.getElementById("searchForm");
        const searchBox = document.getElementById("searchBox");
        const searchResults = document.getElementById("searchResults");
        if (!searchForm || !searchBox || !searchResults) return;
        
        let debounceTimer;
        const RECENT_SEARCHES_KEY = "quizstudy_recent_searches";
        const MAX_RECENT = 5;

        function getRecentSearches() {
            const searches = localStorage.getItem(RECENT_SEARCHES_KEY);
            return searches ? JSON.parse(searches) : [];
        }

        function addRecentSearch(key) {
            if (!key) return;
            let searches = getRecentSearches();
            searches = searches.filter(s => s.toLowerCase() !== key.toLowerCase());
            searches.unshift(key);
            searches = searches.slice(0, MAX_RECENT);
            localStorage.setItem(RECENT_SEARCHES_KEY, JSON.stringify(searches));
        }

        function removeRecentSearch(key) {
            let searches = getRecentSearches();
            searches = searches.filter(s => s.toLowerCase() !== key.toLowerCase());
            localStorage.setItem(RECENT_SEARCHES_KEY, JSON.stringify(searches));
        }

        function showRecentSearches() {
            const searches = getRecentSearches();
            searchResults.innerHTML = "";
            if (searches.length === 0) {
                searchResults.style.display = "none";
                return;
            }

            const header = document.createElement("div");
            header.className = "list-group-item list-group-item-light text-muted small";
            header.innerHTML = "<strong><i class='fa-solid fa-clock-rotate-left me-2'></i>Tìm kiếm gần đây</strong>";
            searchResults.appendChild(header);

            searches.forEach(key => {
                const item = document.createElement("a");
                item.className = "list-group-item list-group-item-action d-flex justify-content-between align-items-center";
                item.href = `/Search?key=${encodeURIComponent(key)}`;
                item.dataset.key = key;
                
                item.innerHTML = `
                    <span>${key}</span>
                    <button type="button" class="btn-close btn-sm p-0 recent-delete-btn" 
                            data-key="${key}" title="Xóa tìm kiếm này"></button>
                `;
                searchResults.appendChild(item);
            });
            searchResults.style.display = "block";
        }

        function showSuggestions(suggestions) {
            searchResults.innerHTML = "";
            if (suggestions.length === 0) {
                searchResults.style.display = "none";
                return;
            }

            const header = document.createElement("div");
            header.className = "list-group-item list-group-item-light text-muted small";
            header.innerHTML = "<strong><i class='fa-solid fa-lightbulb me-2'></i>Gợi ý</strong>";
            searchResults.appendChild(header);

            suggestions.forEach(key => {
                const item = document.createElement("a");
                item.className = "list-group-item list-group-item-action";
                item.href = `/Search?key=${encodeURIComponent(key)}`;
                item.dataset.key = key;
                item.textContent = key;
                searchResults.appendChild(item);
            });
            searchResults.style.display = "block";
        }
        
        async function fetchSuggestions(key) {
            if (key.length < 2) {
                searchResults.style.display = "none";
                return;
            }
            try {
                const response = await fetch(`/Index?handler=Suggestions&key=${encodeURIComponent(key)}`);
                if (!response.ok) return;
                const suggestions = await response.json();
                showSuggestions(suggestions);
            } catch (err) {
                console.error("Lỗi fetch gợi ý:", err);
                searchResults.style.display = "none";
            }
        }

        searchBox.addEventListener("focus", () => {
            if (searchBox.value.trim() === "") {
                showRecentSearches();
            }
        });

        searchBox.addEventListener("input", () => {
            clearTimeout(debounceTimer);
            const key = searchBox.value.trim();
            if (key === "") {
                showRecentSearches();
                return;
            }
            debounceTimer = setTimeout(() => {
                fetchSuggestions(key);
            }, 300);
        });

        searchForm.addEventListener("submit", () => {
            const key = searchBox.value.trim();
            addRecentSearch(key);
        });

        document.addEventListener("click", (e) => {
            if (!searchForm.contains(e.target)) {
                searchResults.style.display = "none";
            }
            
            if (e.target.classList.contains('recent-delete-btn')) {
                e.preventDefault(); 
                e.stopPropagation(); 
                const key = e.target.dataset.key;
                removeRecentSearch(key); 
                e.target.closest('.list-group-item').remove(); 
            }

            const clickedSuggestion = e.target.closest('#searchResults .list-group-item-action');
            if (clickedSuggestion && !e.target.classList.contains('recent-delete-btn')) {
                const key = clickedSuggestion.dataset.key;
                addRecentSearch(key);
            }
        });
    });
</script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: @Html.Raw(Json.Serialize(TempData["SuccessMessage"])),
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        </script>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'error',
                title: @Html.Raw(Json.Serialize(TempData["ErrorMessage"])),
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
        </script>
    }
    @await Component.InvokeAsync("ActiveExamAlert")

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>