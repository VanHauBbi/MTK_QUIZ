<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @ViewData["PanelTitle"]</title>

    <base href="~/" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <link href="~/css/_Layout_Adm.css" rel="stylesheet" asp-append-version="true" />


</head>

<body>
    <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">

        <div class="container-fluid">

            <a class="navbar-brand col-md-3 col-lg-2 me-0 px-5 fs-3" href="#">
                <i class="fa-solid fa-pencil-alt me-2"></i>
                <span style="color: #28a745;">Quiz</span><span style="color: white;">Study</span>
            </a>

            <button class="navbar-toggler position-absolute d-md-none collapsed" type="button"
                    data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-nav ms-auto">
                <div class="nav-item d-flex align-items-center text-nowrap px-5">
                    <i class="fa-solid fa-user me-2 text-white"></i>
                    <span class="navbar-text me-3">
                        @User.Identity?.Name
                    </span>
                    <a class="nav-link" asp-page="/Account/Logout" style="padding-top: 0; padding-bottom: 0;">
                        Đăng xuất
                    </a>
                </div>
            </div>

        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="sidebar-sticky pt-3">
                    

                    @await Component.InvokeAsync("AdminSidebar")
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard-chart.js" asp-append-version="true"></script>
    <script src="~/js/admin-search.js" asp-append-version="true"></script>

    <script src="/_framework/blazor.server.js"></script>


    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: @Html.Raw(Json.Serialize(TempData["SuccessMessage"])),
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true
            });
        </script>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'error',
                title: @Html.Raw(Json.Serialize(TempData["ErrorMessage"])),
                showConfirmButton: false,
                timer: 5000,
                timerProgressBar: true
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

