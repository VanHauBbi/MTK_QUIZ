@model DALTWNC_QUIZ.Models.ViewModels.DashboardCard

<div class="col-lg-3 col-md-6">
    <div class="card text-white bg-@Model.Color shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5>@Model.Value</h5>
                <p class="mb-0">@Model.Title</p>
            </div>
            <i class="fa-solid @Model.Icon fa-3x opacity-50"></i>
        </div>
        <div class="card-footer text-center">
            <a href="@Model.Link" class="small text-white text-decoration-none">
                Xem chi tiết <i class="fa-solid fa-arrow-circle-right ms-1"></i>
            </a>
        </div>
    </div>
</div>
