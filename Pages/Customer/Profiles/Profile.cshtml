@page "{username?}"
@model DALTWNC_QUIZ.Pages.Customer.Profiles.ProfileModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white text-center">
            <h3>Thông tin cá nhân</h3>
        </div>
        <div class="card-body">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.Customer != null)
            {
                <table class="table table-bordered table-striped">
                    <tr>
                        <th>Họ tên</th>
                        <td>@Model.Customer.CustomerName</td>
                    </tr>
                    <tr>
                        <th>Số điện thoại</th>
                        <td>@Model.Customer.CustomerPhone</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>@Model.Customer.CustomerEmail</td>
                    </tr>
                    <tr>
                        <th>Địa chỉ</th>
                        <td>@Model.Customer.CustomerAddress</td>
                    </tr>
                    <tr>
                        <th>Tài khoản</th>
                        <td>@Model.Customer.Username</td>
                    </tr>
                </table>

                <div class="text-center mt-4">
                    <a asp-page="/Customer/Profiles/EditProfile"
                                   asp-route-username="@Model.Customer.Username"
                                   class="btn btn-primary btn-lg me-2">
                        <i class="fa-solid fa-user-pen me-1"></i> Chỉnh sửa thông tin
                    </a>

                    <a asp-page="/Account/ChangePassword"
                                   asp-route-username="@Model.Customer.Username"
                                   class="btn btn-warning btn-lg text-white">
                        <i class="fa-solid fa-key me-1"></i> Đổi mật khẩu
                    </a>
                </div>

            }
            else
            {
                <div class="alert alert-warning text-center">
                    Không tìm thấy thông tin người dùng.
                </div>
            }
        </div>
    </div>
</div>