@page "{username?}"
@model DALTWNC_QUIZ.Pages.Customer.Profiles.EditProfileModel
@{
    ViewData["Title"] = "Chỉnh sửa thông tin cá nhân";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white text-center py-3">
            <h3><i class="fa-solid fa-user-pen me-2"></i> Chỉnh sửa thông tin cá nhân</h3>
        </div>

        <div class="card-body px-4 py-4">
            @if (Model.Customer != null)
            {
                <form method="post"
                      class="needs-validation"
                      novalidate
                      asp-route-username="@Model.Customer.Username">
                    <input type="hidden" asp-for="Customer.CustomerID" />
                    <input type="hidden" asp-for="Customer.Username" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fa-solid fa-user me-1 text-success"></i> Họ và tên
                            </label>
                            <input asp-for="Customer.CustomerName" class="form-control form-control-lg" placeholder="Nhập họ tên..." />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fa-solid fa-envelope me-1 text-success"></i> Email
                            </label>
                            <input asp-for="Customer.CustomerEmail" class="form-control form-control-lg" placeholder="Nhập email..." />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fa-solid fa-phone me-1 text-success"></i> Số điện thoại
                            </label>
                            <input asp-for="Customer.CustomerPhone" class="form-control form-control-lg" placeholder="Nhập số điện thoại..." />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                <i class="fa-solid fa-location-dot me-1 text-success"></i> Địa chỉ
                            </label>
                            <input asp-for="Customer.CustomerAddress" class="form-control form-control-lg" placeholder="Nhập địa chỉ..." />
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <button type="submit" class="btn btn-success btn-lg me-2 shadow-sm px-4">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi
                        </button>

                        <a asp-page="/Customer/Profiles/Profile"
                           asp-route-username="@Model.Customer.Username"
                           class="btn btn-outline-secondary btn-lg shadow-sm px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                        </a>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i> Không tìm thấy thông tin người dùng.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}
