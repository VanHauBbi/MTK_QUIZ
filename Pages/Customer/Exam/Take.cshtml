@page "{id:int}"
@model DALTWNC_QUIZ.Pages.Customer.Exam.TakeModel

@{
    ViewData["Title"] = "Làm bài thi";
    Layout = "_Layout_Cus";
}
<link rel="stylesheet" href="~/css/Take_Exam/Take.css" asp-append-version="true" />
<div class="container mt-4">
    @if (!Model.IsExamStarted)
    {
        <div class="card shadow-lg text-center p-5 mx-auto" style="max-width: 600px;">
            <div class="card-body">
                <h2 class="text-primary mb-3">@Model.Quiz.QuizTitle</h2>
                <div class="mb-4">
                    <span class="badge bg-info fs-6 me-2"><i class="fa-regular fa-clock"></i> @Model.Duration phút</span>
                    <span class="badge bg-secondary fs-6"><i class="fa-solid fa-list-ol"></i> @Model.Quiz.TotalQuestions câu hỏi</span>
                </div>
                <div class="alert alert-warning text-start">
                    <h5><i class="fa-solid fa-circle-info"></i> Lưu ý trước khi thi:</h5>
                    <ul class="mb-0">
                        <li>Thời gian sẽ bắt đầu tính ngay khi bạn bấm nút "Bắt đầu".</li>
                        <li>Hệ thống có tính năng <strong>Chống gian lận</strong>: Rời màn hình quá 3 lần sẽ bị thu bài.</li>
                        <li>Tiến độ làm bài được lưu tự động.</li>
                    </ul>
                </div>

                <form method="post" asp-page-handler="Start" asp-route-id="@Model.Id">
                    <button type="submit" class="btn btn-success btn-lg w-100 mt-3">
                        <i class="fa-solid fa-play"></i> BẮT ĐẦU LÀM BÀI
                    </button>
                </form>
                <a href="/" class="btn btn-outline-secondary w-100 mt-2">Quay lại trang chủ</a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8 unselectable">
                <h3>@Model.Quiz.QuizTitle</h3>
                <p class="text-muted">
                    <i class="fa-regular fa-circle-question"></i> @Model.Questions.Count câu hỏi |
                    <i class="fa-regular fa-clock"></i> @Model.Duration phút
                </p>

                <form method="post" id="quizQuestionsForm">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CurrentAttemptID" />
                    <input type="hidden" asp-for="ElapsedSeconds" id="elapsedSecondsInput" />

                    @for (int i = 0; i < Model.Questions.Count; i++)
                    {
                        var q = Model.Questions[i];
                        <div class="question-card mb-4 p-4 rounded-3 shadow-sm bg-white border position-relative" id="question-@(i + 1)">
                            <button type="button" class="flag-btn btn position-absolute top-0 end-0 m-2"
                                    data-question="@(i + 1)" title="Đánh dấu câu hỏi">
                                🚩
                            </button>

                            <div class="mb-2 pe-4">
                                <strong>Câu @(i + 1):</strong> @q.QuestionText
                            </div>

                            <div class="mt-2">
                                @foreach (var choice in q.Choices)
                                {
                                    <div class="form-check my-1">
                                        <input type="radio"
                                               name="Answers[@(q.QuestionID)]"
                                               value="@choice.ChoiceID"
                                               id="choice_@choice.ChoiceID"
                                               class="form-check-input answer-option"
                                               data-question="@(i + 1)" />
                                        <label class="form-check-label" for="choice_@choice.ChoiceID">@choice.ChoiceText</label>
                                    </div>
                                }
                            </div>
                            <div class="text-end mt-2">
                                <button type="button" class="btn btn-outline-danger btn-sm clear-answer-btn" data-question="@(i + 1)">
                                    <i class="bi bi-x-circle"></i> Xóa câu trả lời
                                </button>
                            </div>
                        </div>
                    }
                </form>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div id="timerHeader" class="card-header text-white text-center @Model.TimerUIState.GetColorClass()">
                        <strong>🕒 Thời gian còn lại</strong>
                    </div>
                    <div class="card-body text-center">
                        <h4 id="timeDisplay" class="fw-bold mb-3">00:00</h4>
                        <p id="timerMessage" class="small fw-bold">@Model.TimerUIState.GetMessage()</p>

                        <button id="submitBtn" type="button" class="btn btn-danger w-100 mb-3">Nộp bài</button>
                        <hr />
                        <div id="question-nav" class="mt-3 question-panel">
                            @for (int i = 0; i < Model.Questions.Count; i++)
                            {
                                <button type="button" id="btn-q@(i + 1)" class="btn btn-outline-secondary m-1 question-btn" data-question="@(i + 1)">
                                    @(i + 1)
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.IsExamStarted)
{
    @section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.addEventListener('contextmenu', event => {
                event.preventDefault();
            });

            document.onkeydown = function (e) {
                if (e.ctrlKey &&
                    (e.keyCode === 67 ||
                        e.keyCode === 86 ||
                        e.keyCode === 85 ||
                        e.keyCode === 88 ||
                        e.keyCode === 65)) {
                    return false;
                }
            };

            document.addEventListener('copy', e => e.preventDefault());
            document.addEventListener('cut', e => e.preventDefault());
            document.addEventListener('paste', e => e.preventDefault());
        });
    </script>

    <script>
        const storageKeyAnswers = "quiz_answers_@Model.CurrentAttemptID";
        const storageKeyFlags = "quiz_flags_@Model.CurrentAttemptID";
        let savedAnswers = JSON.parse(localStorage.getItem(storageKeyAnswers)) || {};
        let savedFlags = JSON.parse(localStorage.getItem(storageKeyFlags)) || {};

        let isSubmitting = false;
        let violationCount = 0;
        const maxViolations = 3;

        document.addEventListener("visibilitychange", () => {
            if (!isSubmitting) {
                if (document.hidden) {
                    violationCount++;
                    document.title = "⚠️ CẢNH BÁO! QUAY LẠI NGAY";

                    if (violationCount >= maxViolations) {
                        forceSubmitCheating();
                    } else {
                        Swal.fire({
                            title: 'Cảnh báo gian lận!',
                            html: `Bạn đã rời màn hình thi. Vi phạm: <b class="text-danger">${violationCount}/${maxViolations}</b>.<br>Quá 3 lần sẽ bị thu bài!`,
                            icon: 'warning',
                            confirmButtonText: 'Đã hiểu'
                        });
                    }
                } else {
                    document.title = "Làm bài thi";
                }
            }
        });

        function forceSubmitCheating() {
            isSubmitting = true;

            let timerInterval;
            Swal.fire({
                title: 'ĐÌNH CHỈ THI!',
                html: 'Bạn đã vi phạm quy chế thi (rời màn hình quá 3 lần).<br><br>' +
                    'Hệ thống sẽ <b>tự động thu bài</b> sau <b></b> giây.',
                icon: 'error',
                timer: 5000,
                timerProgressBar: true,
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: true,
                confirmButtonText: 'Nộp bài ngay',
                confirmButtonColor: '#d33',

                didOpen: () => {
                    const b = Swal.getHtmlContainer().querySelector('b:last-child');
                    timerInterval = setInterval(() => {
                        if (b) {
                            b.textContent = Math.ceil(Swal.getTimerLeft() / 1000);
                        }
                    }, 100);
                },
                willClose: () => {
                    clearInterval(timerInterval);
                }
            }).then((result) => {
                window.doSubmitLogic();
            });
        }

        window.addEventListener('beforeunload', function (e) {
            if (!isSubmitting) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        function confirmExit() {
            Swal.fire({
                title: 'Cảnh báo thoát',
                text: "Đồng hồ vẫn đang chạy! Bạn có chắc muốn thoát?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Thoát',
                cancelButtonText: 'Ở lại'
            }).then((result) => {
                if (result.isConfirmed) {
                    isSubmitting = true;
                    history.back();
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const quizForm = document.getElementById('quizQuestionsForm');
            const submitBtn = document.getElementById("submitBtn");
            const timeDisplay = document.getElementById("timeDisplay");
            const timerHeader = document.getElementById("timerHeader");
            const timerMessage = document.getElementById("timerMessage");
            const elapsedInput = document.getElementById("elapsedSecondsInput");

            const maxSeconds = @Model.Duration * 60;
            let totalSeconds = @Model.RemainingSeconds;
            let timerInterval = null;

            const inputs = document.querySelectorAll(".answer-option");
            const flags = document.querySelectorAll(".flag-btn");
            const clears = document.querySelectorAll(".clear-answer-btn");

            initExam();

            function initExam() {
                restoreFlags();
                restoreAnswers();
                updateTimerDisplay();
                timerInterval = setInterval(timerLogic, 1000);
            }

            function timerLogic() {
                if (totalSeconds <= 0) {
                    clearInterval(timerInterval);
                    autoSubmitTimeOut();
                } else {
                    totalSeconds--;
                    updateTimerDisplay();
                }
            }
            function updateTimerDisplay() {
                let m = Math.floor(totalSeconds / 60);
                let s = totalSeconds % 60;
                timeDisplay.innerText = `${m}:${s.toString().padStart(2, '0')}`;

                const ratio = totalSeconds / maxSeconds;

                if (totalSeconds <= 60) {
                    timerHeader.className = "card-header text-white text-center bg-danger animate-pulse";
                    timeDisplay.className = "fw-bold text-danger mb-3";
                    timerMessage.innerText = "KHẨN CẤP! Nộp bài ngay kẻo lỡ!";
                    timerMessage.className = "small fw-bold text-danger";
                } else if (ratio < 0.3) {
                    
                    timerHeader.className = "card-header text-center bg-warning text-dark";
                    timeDisplay.className = "fw-bold text-warning mb-3";
                    timerMessage.innerText = "Nhanh tay lên nào, thời gian không còn nhiều!";
                    timerMessage.className = "small fw-bold text-warning";
                } else {
                    
                    timerHeader.className = "card-header text-white text-center bg-success";
                    timeDisplay.className = "fw-bold text-success mb-3";
                    timerMessage.innerText = "Bạn cứ bình tĩnh làm bài nhé.";
                    timerMessage.className = "small fw-bold text-success";
                }
            }

            function updateNavButtonStatus(qNum) {
                const navBtn = document.getElementById(`btn-q${qNum}`);
                const flagBtn = document.querySelector(`.flag-btn[data-question="${qNum}"]`);
                const questionCard = document.getElementById(`question-${qNum}`);
                const isAnswered = questionCard.querySelector('input[type="radio"]:checked') !== null;
                const isFlagged = flagBtn.classList.contains("flagged");

                navBtn.className = "btn m-1 question-btn";

                if (isAnswered && isFlagged) {
                    navBtn.classList.add("btn-success", "btn-flagged-answered");
                } else if (isAnswered) {
                    navBtn.classList.add("btn-success");
                } else if (isFlagged) {
                    navBtn.classList.add("btn-flagged");
                } else {
                    navBtn.classList.add("btn-outline-secondary");
                }
            }

            inputs.forEach(input => {
                input.addEventListener("change", function () {
                    const qNum = this.getAttribute("data-question");
                    const match = this.name.match(/\[(\d+)\]/);
                    if (match) {
                        savedAnswers[match[1]] = this.value;
                        localStorage.setItem(storageKeyAnswers, JSON.stringify(savedAnswers));
                    }
                    updateNavButtonStatus(qNum);
                });
            });

            flags.forEach(btn => {
                btn.addEventListener("click", function () {
                    this.classList.toggle("flagged");
                    const qNum = this.getAttribute("data-question");
                    if (this.classList.contains("flagged")) {
                        savedFlags[qNum] = true;
                    } else {
                        delete savedFlags[qNum];
                    }
                    localStorage.setItem(storageKeyFlags, JSON.stringify(savedFlags));
                    updateNavButtonStatus(qNum);
                });
            });

            clears.forEach(btn => {
                btn.addEventListener("click", function () {
                    const qNum = this.getAttribute("data-question");
                    const card = document.getElementById(`question-${qNum}`);
                    const radios = card.querySelectorAll(`input[type="radio"]`);
                    radios.forEach(r => r.checked = false);
                    if (radios.length > 0) {
                        const match = radios[0].name.match(/\[(\d+)\]/);
                        if (match) {
                            delete savedAnswers[match[1]];
                            localStorage.setItem(storageKeyAnswers, JSON.stringify(savedAnswers));
                        }
                    }
                    updateNavButtonStatus(qNum);
                });
            });

            function restoreFlags() {
                Object.keys(savedFlags).forEach(qNum => {
                    const btn = document.querySelector(`.flag-btn[data-question="${qNum}"]`);
                    if (btn) {
                        btn.classList.add("flagged");
                        updateNavButtonStatus(qNum);
                    }
                });
            }

            function restoreAnswers() {
                inputs.forEach(input => {
                    const match = input.name.match(/\[(\d+)\]/);
                    if (match) {
                        const qId = match[1];
                        if (savedAnswers[qId] == input.value) {
                            input.checked = true;
                            updateNavButtonStatus(input.getAttribute("data-question"));
                        }
                    }
                });
            }

            submitBtn.addEventListener('click', () => {
                Swal.fire({
                    title: 'Nộp bài?',
                    text: "Bạn có chắc chắn muốn nộp?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Nộp ngay'
                }).then((r) => {
                    if (r.isConfirmed) {
                        isSubmitting = true;
                        window.doSubmitLogic();
                    }
                });
            });

            function autoSubmitTimeOut() {
                isSubmitting = true;
                Swal.fire({ title: 'Hết giờ!', text: 'Đang nộp bài...', timer: 2000, showConfirmButton: false });
                window.doSubmitLogic();
            }

            window.doSubmitLogic = function () {
                let elapsed = maxSeconds - totalSeconds;
                if (elapsed < 0) elapsed = 0;
                elapsedInput.value = elapsed;

                localStorage.removeItem(storageKeyAnswers);
                localStorage.removeItem(storageKeyFlags);

                quizForm.submit();
            }

            document.querySelectorAll(".question-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    document.getElementById("question-" + this.dataset.question).scrollIntoView({ behavior: "smooth", block: "center" });
                });
            });
        });
    </script>
    }
}