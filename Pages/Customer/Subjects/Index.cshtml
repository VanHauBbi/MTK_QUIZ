@page
@model DALTWNC_QUIZ.Pages.Customer.Subjects.IndexModel
@{
    ViewData["Title"] = "Danh sách Môn học";
}

<div class="container mt-4">
    <div class="mb-3">
        <a href="javascript:void(0);" onclick="history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>
            Quay lại
        </a>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-3">

        <h3 class="section-title">@ViewData["Title"]</h3>

    </div>

    <div class="row g-4">
        @if (!Model.SubjectList.Any())
        {
            <p class="text-muted">Chưa có môn học nào được tạo.</p>
        }
        else
        {
            @foreach (var subject in Model.SubjectList)
            {
                <div class="col-md-3">
                    <a asp-page="/Customer/SubjectQuizzes/Index" asp-route-id="@subject.SubjectID" class="text-decoration-none">

                        <div class="card quiz-card h-100 shadow-sm">
                            <div class="card-body text-center p-4">

                                <i class="fa-solid fa-book fa-2x text-primary mb-2"></i>

                                <h5 class="card-title quiz-card-title" style="min-height: 0;">
                                    @subject.SubjectName
                                </h5>

                                <p class="text-muted mb-0" style="font-size: 0.9rem;">
                                    @subject.QuizCount bộ đề
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>