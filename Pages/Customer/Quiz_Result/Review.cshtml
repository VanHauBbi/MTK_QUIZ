@page "{id:int}"
@model DALTWNC_QUIZ.Pages.Customer.Quiz_Result.ReviewModel
@{
    ViewData["Title"] = "Xem lại bài thi";
    Layout = "_Layout_Cus";
}

<style>
    .choice-item {
        padding: 0.75rem 1.25rem;
        margin-bottom: 0.5rem;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        transition: background-color 0.2s;
    }

    .choice-correct {
        background-color: #d1e7dd;
        border-color: #badbcc;
        font-weight: bold;
        color: #0f5132;
    }

    .choice-incorrect {
        background-color: #f8d7da;
        border-color: #f5c2c7;
        color: #842029;
        text-decoration: line-through;
        opacity: 0.8;
    }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-dark text-white text-center">
                    <strong>CHI TIẾT KẾT QUẢ</strong>
                </div>
                <div class="card-body text-center">
                    <h5 class="card-title">@Model.Quiz.QuizTitle</h5>
                    <p class="text-muted">@Model.Quiz.Subject.SubjectName</p>
                    <hr>
                    <p class="display-4 fw-bold text-primary">@Model.ExamResult.Score.Value.ToString("0.##") <span class="fs-4">Điểm</span></p>
                    <p>
                        Số câu đúng: @Model.ExamResult.CorrectAnswers / @Model.ExamResult.TotalQuestions
                    </p>

                    <hr />

                    <div class="d-grid gap-2">
                        <form method="post" asp-page="/Customer/Quiz_Result/Result" asp-page-handler="Retake" style="display:inline;">
                            <input type="hidden" name="resultId" value="@Model.ExamResult.QuizAttemptID" />
                            <input type="hidden" name="quizId" value="@Model.ExamResult.QuizID" />
                            <button type="submit" class="btn btn-success w-100">Làm lại</button>
                        </form>

                        <a asp-page="/Customer/SubjectQuizzes/Index" asp-route-id="@Model.Quiz.SubjectID" class="btn btn-outline-primary">Làm đề môn tương tự</a>
                        <a asp-page="/Customer/Subjects/Index" class="btn btn-secondary">Làm đề môn khác</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <h2 class="mb-4">Đáp án chi tiết</h2>
            @if (Model.Questions != null)
            {
                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    var q = Model.Questions[i];
                    Model.UserAnswersMap.TryGetValue(q.QuestionID, out int? userChoiceId);

                    <div class="question-card mb-4 p-4 rounded-3 shadow-sm bg-white border" id="question-@(i + 1)">
                        <div class="mb-2 pe-4">
                            <strong>Câu @(i + 1):</strong> @q.QuestionText
                        </div>

                        <div class="mt-3">
                            @foreach (var choice in q.Choices)
                            {
                                string highlightClass = "";
                                string iconHtml = "";

                                bool isCorrect = choice.IsCorrect;
                                bool isUserSelected = (choice.ChoiceID == userChoiceId);

                                if (isCorrect)
                                {
                                    highlightClass = "choice-correct";
                                    iconHtml = "<i class='bi bi-check-circle-fill me-2'></i>";
                                }
                                else if (isUserSelected && !isCorrect)
                                {
                                    highlightClass = "choice-incorrect";
                                    iconHtml = "<i class='bi bi-x-circle-fill me-2'></i>";
                                }
                                else
                                {
                                    iconHtml = "<i class='bi bi-circle me-2' style='opacity: 0.5;'></i>";
                                }

                                <div class="choice-item @highlightClass">
                                    @Html.Raw(iconHtml)
                                    <span>@choice.ChoiceText</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>