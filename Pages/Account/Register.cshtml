@page
@model DALTWNC_QUIZ.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - QuizSystem</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/account.css" rel="stylesheet" />
</head>
<body>
    <div class="register-container">
        <h3>Đăng ký</h3>
        <form method="post">
            <input type="text" class="form-control" placeholder="Họ và tên" asp-for="Input.CustomerName" required />
            <input type="text" class="form-control" placeholder="Tên đăng nhập" asp-for="Input.Username" required />
            <input type="text" class="form-control" placeholder="Số điện thoại" asp-for="Input.CustomerPhone" required />
            <input type="email" class="form-control" placeholder="Email" asp-for="Input.CustomerEmail" />
            <input type="text" class="form-control" placeholder="Địa chỉ" asp-for="Input.CustomerAddress" />
            <input type="password" class="form-control" placeholder="Mật khẩu" asp-for="Input.Password" required />
            <input type="password" class="form-control" placeholder="Xác nhận mật khẩu" asp-for="Input.ConfirmPassword" required />

            <button type="submit" class="btn btn-primary">Đăng ký</button>

            <button type="button" class="google-btn">
                <img src="https://cdn-icons-png.flaticon.com/512/281/281764.png" width="18" /> Google
            </button>

            <div class="login-link">
                <span>Bạn đã có tài khoản?</span> <a asp-page="Login">Đăng nhập ngay.</a>
            </div>
        </form>
    </div>
</body>
</html>