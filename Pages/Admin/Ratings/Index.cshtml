@page
@model DALTWNC_QUIZ.Pages.Admin.Ratings.IndexModel
@using DALTWNC_QUIZ.Models
@{
    ViewData["Title"] = "Quản lý Đánh giá";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>

    <div class="d-flex align-items-center gap-2">
        <form method="get" class="d-flex" style="width: 300px;">
            <div class="input-group input-group-sm">
                <input type="search"
                       name="query"
                       value="@Model.query"
                       class="form-control"
                       placeholder="Tìm kiếm đánh giá..."
                       aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit" title="Tìm kiếm">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
        </form>

        <a href="javascript:void(0);" onclick="history.back();" class="btn btn-outline-secondary btn-sm" title="Quay lại">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Danh sách Đánh giá</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <quiz-table-head>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Khách hàng</th>
                        <th>Bộ đề thi</th>
                        <th class="text-center">Số sao</th>
                        
                        <th class="text-center">Ngày đánh giá</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </quiz-table-head>

                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model.RatingList)
                    {
                        <tr class="align-middle">
                            <td class="text-center">@(stt++)</td>
                            <td>@(item.Customer?.CustomerName ?? "N/A")</td>
                            <td>@(item.Quiz?.QuizTitle ?? "N/A")</td>
                            <td class="text-center">
                                @for (int i = 0; i < item.Stars; i++)
                                {
                                    <i class="fa-solid fa-star text-warning"></i>
                                }
                                @for (int i = item.Stars; i < 5; i++)
                                {
                                    <i class="fa-regular fa-star text-muted"></i>
                                }
                                (@item.Stars)
                            </td>
                            <td class="text-center">@item.RatingDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-nowrap">
                                <div class="d-flex justify-content-center">
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.RatingID"
                                          class="form-delete d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.RatingList.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">Chưa có đánh giá nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div route-data="true"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteForms = document.querySelectorAll('.form-delete');
            deleteForms.forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    var currentForm = this;

                    Swal.fire({
                        title: 'Bạn có chắc chắn?',
                        text: "Bạn muốn xóa đánh giá này?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Vâng, xóa nó!',
                        cancelButtonText: 'Hủy'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            currentForm.submit();
                        }
                    });
                });
            });
        });

        const searchForm = document.querySelector("form[method='get']");
        const searchInput = searchForm?.querySelector("input[name='query']");
        if (searchForm) {
            searchForm.addEventListener("submit", function (e) {
                if (!searchInput.value.trim()) {
                    e.preventDefault();
                    Swal.fire({
                        icon: "warning",
                        title: "Chưa nhập từ khóa!",
                        text: "Vui lòng nhập từ khóa để tìm kiếm.",
                        confirmButtonText: "OK"
                    });
                }
            });
        }

        @if (TempData["NoResults"] != null)
        {
            <text>
                    Swal.fire({
                        icon: "info",
                    title: "Không có kết quả!",
                    text: "Không tìm thấy môn học phù hợp với từ khóa",
                    confirmButtonText: "Đóng"
            </text>
        }
    </script>
}