@page
@model DALTWNC_QUIZ.Pages.Admin.Quizzes.SelectQuestionsModel
@using DALTWNC_QUIZ.Models
@{
    ViewData["Title"] = "Thêm Câu hỏi";
    ViewData["ActivePage"] = "Quizzes";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div style ="width: 60%;">
        <h1 class="h2">Thêm Câu hỏi</h1>
        <h5 class="text-muted">
            Bộ đề: @Model.Quiz.QuizTitle (Số lượng mong muốn: @Model.Quiz.TotalQuestions)
        </h5>
        <small class="text-info">Môn học: @Model.Subject.SubjectName</small>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <form method="post"
              asp-page-handler="Finalize"
              asp-route-quizId="@Model.QuizId"
              asp-route-subjectId="@Model.SubjectId"
              class="d-inline me-2">
            <input type="hidden" name="handler" value="Randomize" />
            <button type="submit" class="btn btn-warning">
                <i class="fa-solid fa-dice me-2"></i> Random @Model.Quiz.TotalQuestions Câu hỏi
            </button>
        </form>

        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm" title="Quay lại danh sách">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<form id="manualForm" method="post"
      asp-page-handler="Finalize"
      asp-route-quizId="@Model.QuizId"
      asp-route-subjectId="@Model.SubjectId">
    <input type="hidden" name="handler" value="Manual" />

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h5 class="mb-0">Danh sách Câu hỏi có sẵn (@Model.AvailableQuestions.Count)</h5>
        </div>
        <div class="card-body">
            @if (!Model.AvailableQuestions.Any())
            {
                <div class="alert alert-info">
                    Không có câu hỏi nào thuộc môn học này để thêm vào.
                </div>
            }
            else
            {
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-center" style="width: 50px;">
                                <input type="checkbox" id="checkAll" />
                            </th>
                            <th class="text-center" style="width: 80px;">ID</th>
                            <th>Nội dung Câu hỏi</th>
                            <th style="width: 150px;">Danh mục</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in Model.AvailableQuestions)
                        {
                            <tr class="align-middle">
                                <td class="text-center">
                                    <input type="checkbox" name="SelectedQuestionIds" value="@q.QuestionID" class="select-q"
                                    @(Model.CurrentlySelectedIds.Contains(q.QuestionID) ? "checked" : "") />
                                </td>
                                <td class="text-center">@q.QuestionID</td>
                                <td>@q.QuestionText</td>
                                <td>@(q.QuestionCategory?.CategoryName ?? "N/A")</td>
                            </tr>
                        }
                    </tbody>

                </table>

                <button type="submit" class="btn btn-primary mt-3">
                    <i class="fa-solid fa-save me-2"></i> Lưu Câu hỏi đã chọn
                </button>
            }
        </div>
    </div>
</form>
@section Scripts {
    <script>
        function showValidationToast(icon, message) {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: icon,
                title: message,
                showConfirmButton: false,
                timer: 4500,
                timerProgressBar: true
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            const checkAll = document.getElementById("checkAll");
            const form = document.getElementById("manualForm");
            const totalAllowed = @Model.Quiz.TotalQuestions;

            function getCheckboxes() {
                return Array.from(document.querySelectorAll('input.select-q[name="SelectedQuestionIds"]'));
            }

            if (checkAll) {
                checkAll.addEventListener("change", function () {
                    const boxes = getCheckboxes();
                    if (this.checked && boxes.length > totalAllowed) {
                        Swal.fire({
                            icon: "warning",
                            title: "Vượt quá giới hạn",
                            text: `Không thể chọn tất cả ${boxes.length} câu — vượt quá số lượng yêu cầu (${totalAllowed}).`
                        });
                        this.checked = false;
                        return;
                    }
                    boxes.forEach(cb => cb.checked = this.checked);
                });
            }

            document.addEventListener("change", function (e) {
                if (!e.target.classList || !e.target.classList.contains("select-q")) return;
                const boxes = getCheckboxes();
                const allChecked = boxes.length > 0 && boxes.every(b => b.checked);
                if (checkAll) checkAll.checked = allChecked;
            });

            if (form) {
                form.addEventListener("submit", function (e) {
                    const handlerInput = form.querySelector('input[name="handler"]');
                    const handler = handlerInput ? handlerInput.value : null;

                    if (handler === "Randomize") return;

                    const selected = getCheckboxes().filter(c => c.checked).length;

                    if (selected === 0) {
                        e.preventDefault();
                        showValidationToast('info', "Vui lòng chọn ít nhất một câu hỏi hoặc dùng Random.");
                        return;
                    }

                    if (selected > totalAllowed) {
                        e.preventDefault();
                        showValidationToast('error', `Bạn đã chọn ${selected} câu, vượt quá số lượng mong muốn (${totalAllowed}).`);
                        return;
                    }
                });
            }
        });
    </script>
}
