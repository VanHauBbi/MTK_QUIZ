@page
@model DALTWNC_QUIZ.Pages.Admin.Quizzes.IndexModel
@{
    ViewData["Title"] = "Quản lý Bộ đề thi";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-2">
        <form method="get" class="d-flex" style="width: 300px;">
            <div class="input-group input-group-sm">
                <input type="search"
                       name="query"
                       value="@Model.query"
                       class="form-control"
                       placeholder="Tìm kiếm bộ đề..."
                       aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit" title="Tìm kiếm">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
        </form>

        <a asp-page="Create" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus me-2"></i> Tạo Bộ đề mới
        </a>

        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm" title="Quay lại danh sách">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header"><h5 class="mb-0">Danh sách Bộ đề</h5></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <quiz-table-head>
                    <tr>
                        <th style="width: 35%;">Tên Bộ đề</th>
                        <th>Thuộc Môn học</th>
                        <th class="text-center">Số câu</th>
                        <th>Người tạo</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </quiz-table-head>

                <tbody>
                    @foreach (var item in Model.QuizList)
                    {
                        <tr class="align-middle">
                            <td class="fw-bold">@item.QuizTitle</td>
                            <td>@(item.Subject?.SubjectName ?? "N/A")</td>

                            <td class="text-center">
                                @item.QuizQuestions.Count / @item.TotalQuestions
                            </td>

                            <td>@(item.User?.Username ?? "N/A")</td>
                            <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>

                            <td class="text-center">
                                @if (item.IsPublic)
                                {
                                    <span class="badge bg-success">Công khai</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Riêng tư</span>
                                }
                            </td>
                            <td class="text-center" style="width: 150px;">
                                <div class="d-flex justify-content-center">

                                    <a asp-page="SelectQuestions" asp-route-quizId="@item.QuizID"
                                       asp-route-subjectId="@item.SubjectID"
                                       class="btn btn-sm btn-outline-success me-1" title="Thêm/Sửa Câu hỏi">
                                        <i class="fa-solid fa-list-ol"></i>
                                    </a>
                                    <a asp-page="./Edit" asp-route-id="@item.QuizID"
                                       class="btn btn-sm btn-outline-primary me-1" title="Sửa thông tin đề">
                                        <i class="fa-solid fa-pencil"></i>
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.QuizID" class="form-delete d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.QuizList.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center">Chưa có bộ đề nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div route-data="true"></div>

@section Scripts {
    <script>
    const searchForm = document.querySelector("form[method='get']");
    const searchInput = searchForm?.querySelector("input[name='query']");
    if (searchForm) {
        searchForm.addEventListener("submit", function (e) {
            if (!searchInput.value.trim()) {
                e.preventDefault();
                Swal.fire({
                    icon: "warning",
                    title: "Chưa nhập từ khóa!",
                    text: "Vui lòng nhập từ khóa để tìm kiếm.",
                    confirmButtonText: "OK"
                });
            }
        });
    }

    @if (TempData["NoResults"] != null)
    {
        <text>
            Swal.fire({
            icon: "info",
            title: "Không có kết quả!",
            text: "Không tìm thấy môn học phù hợp với từ khóa",
            confirmButtonText: "Đóng"
        </text>
    }
    </script>
}