@page "{id:int?}"
@model DALTWNC_QUIZ.Pages.Admin.Quizzes.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa Bộ đề";
    ViewData["ActivePage"] = "Quizzes";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm" title="Quay lại">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Thông tin Bộ đề</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <input type="hidden" asp-for="Quiz.QuizID" />
                    <input type="hidden" asp-for="Quiz.CreatedBy" />
                    <input type="hidden" asp-for="Quiz.CreatedDate" />

                    <div class="mb-3">
                        <label asp-for="Quiz.QuizTitle" class="form-label">Tên Bộ đề</label>
                        <input asp-for="Quiz.QuizTitle" class="form-control" required />
                        <span asp-validation-for="Quiz.QuizTitle" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="SubjectFilterId" class="form-label">Môn học</label>
                            <select name="SubjectFilterId" id="SubjectFilterId" asp-for="SubjectFilterId" asp-items="Model.SubjectSL" class="form-select" required>
                                <option value="0">-- Vui lòng chọn Môn học --</option>
                            </select>
                            <span asp-validation-for="SubjectFilterId" class="text-danger"></span>
                            
                            <small class="form-text text-danger mt-1 d-none" id="subjectWarning">
                                ⚠️ Thay đổi môn học sẽ xóa toàn bộ câu hỏi đã chọn (@Model.CurrentQuestionCount câu).
                            </small>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Quiz.TotalQuestions" class="form-label">Số lượng Câu hỏi</label>
                            <input asp-for="Quiz.TotalQuestions" type="number" min="1" class="form-control" required />
                            <span asp-validation-for="Quiz.TotalQuestions" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Quiz.Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Quiz.Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Quiz.IsDynamic" class="form-check-input" type="checkbox" id="isDynamicCheck" />
                        <label asp-for="Quiz.IsDynamic" class="form-check-label">Đây là bộ đề tự động (random câu hỏi)</label>
                        <div class="form-text mt-1" id="dynamicHelpText">
                            Nếu check, hệ thống sẽ tự random câu hỏi và không cần bước "Chọn câu hỏi".
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" asp-for="Quiz.IsPublic" />
                        <label class="form-check-label" asp-for="Quiz.IsPublic">Công khai</label>
                    </div>

                    <button type="submit" class="btn btn-primary" id="submitButton">
                        <i class="fa-solid fa-save me-2"></i> 
                        <span id="submitButtonText">Lưu & Sửa câu hỏi</span>
                    </button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4" id="fixedQuizPanel">
         <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">
                    <i class="fa-solid fa-list-ul me-2"></i> Câu hỏi đã chọn
                    (@Model.CurrentQuestionCount / @Model.Quiz.TotalQuestions)
                </h5>
            </div>
            <div class="card-body p-3">
                @if (Model.CurrentQuestionCount == 0)
                {
                    <p class="text-info mb-0">Bộ đề này chưa có câu hỏi cố định nào.</p>
                }
                else
                {
                    <p>Bộ đề này có <strong>@Model.CurrentQuestionCount câu hỏi cố định</strong>.</p>
                    <p>Bạn có thể thêm/bớt câu hỏi bằng cách nhấn "Lưu & Sửa câu hỏi".</p>
                }
                 <a asp-page="SelectQuestions" 
                    asp-route-quizId="@Model.Quiz.QuizID"
                    asp-route-subjectId="@Model.SubjectFilterId"
                    class="btn btn-outline-success mt-2">
                     <i class="fa-solid fa-list-ol me-2"></i> Quản lý câu hỏi
                 </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const checkbox = document.getElementById('isDynamicCheck');
            const buttonText = document.getElementById('submitButtonText');
            const totalQuestionsLabel = document.querySelector('label[for="Quiz_TotalQuestions"]');
            const dynamicHelpText = document.getElementById('dynamicHelpText');
            
            const fixedQuizPanel = document.getElementById('fixedQuizPanel'); 
            const subjectSelect = document.getElementById('SubjectFilterId');
            const subjectWarning = document.getElementById('subjectWarning');
            const originalSubjectId = @Model.Quiz.SubjectID;
            const currentQuestionCount = @Model.CurrentQuestionCount;

            function toggleQuizType() {
                if (checkbox.checked) {
                    buttonText.textContent = 'Lưu & Hoàn tất';
                    totalQuestionsLabel.textContent = 'Số lượng câu hỏi (Tự động)';
                    dynamicHelpText.textContent = "Hệ thống sẽ random đúng số lượng này từ ngân hàng câu hỏi.";
                    
                    fixedQuizPanel.style.display = 'none';
                    subjectWarning.classList.add('d-none');
                } else {
                    buttonText.textContent = 'Lưu & Sửa câu hỏi';
                    totalQuestionsLabel.textContent = 'Số lượng câu hỏi (Cố định)';
                    dynamicHelpText.textContent = "Đây là SỐ CÂU TỐI ĐA bạn được phép chọn ở bước sau.";
                    
                    fixedQuizPanel.style.display = 'block';
                    checkSubjectWarning(); 
                }
            }
            
            function checkSubjectWarning() {
                if (currentQuestionCount > 0 && parseInt(subjectSelect.value) !== originalSubjectId) {
                    subjectWarning.classList.remove('d-none');
                } else {
                    subjectWarning.classList.add('d-none');
                }
            }

            toggleQuizType();
            
            checkbox.addEventListener('change', toggleQuizType);
            
            subjectSelect.addEventListener('change', function() {
                if (!checkbox.checked) {
                    checkSubjectWarning();
                }
            });
        });
    </script>
}