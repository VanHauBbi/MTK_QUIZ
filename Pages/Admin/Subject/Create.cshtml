@page
@model DALTWNC_QUIZ.Pages.Admin.Subject.CreateModel
@{
    ViewData["Title"] = "Tạo Môn học mới";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Thông tin Môn học</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="NewSubject.SubjectName" class="form-label">Tên Môn học</label>
                    <input asp-for="NewSubject.SubjectName" class="form-control" placeholder="Ví dụ: Toán 10" required />
                    <span asp-validation-for="NewSubject.SubjectName" class="text-danger"></span>
                </div>
                
                <div class="col-md-6">
                    <label asp-for="NewSubject.ParentID" class="form-label">Môn học cha (nếu có)</label>
                    <select asp-for="NewSubject.ParentID" asp-items="@Model.ParentSubjectSL" class="form-select">
                        <option value="0">-- Không có môn cha --</option>
                    </select>
                </div>
            </div>
            
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-save me-2"></i> Lưu lại
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>