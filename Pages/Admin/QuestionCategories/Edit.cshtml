@page
@model DALTWNC_QUIZ.Pages.Admin.QuestionCategories.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa Danh mục";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="mt-4">
        <a href="javascript:void(0);" onclick="history.back();" class="btn btn-outline-secondary btn-sm" title="Quay lại">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Thông tin Danh mục</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <form method="post">
                    <input type="hidden" asp-for="CategoryToEdit.CategoryID" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CategoryToEdit.CategoryName" class="form-label">Tên Danh mục</label>
                        <input asp-for="CategoryToEdit.CategoryName" class="form-control" required />
                        <span asp-validation-for="CategoryToEdit.CategoryName" class="text-danger"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-save me-2"></i> Lưu thay đổi
                        </button>
                        
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>