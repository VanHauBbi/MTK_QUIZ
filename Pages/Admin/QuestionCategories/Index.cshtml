@page
@model DALTWNC_QUIZ.Pages.Admin.QuestionCategories.IndexModel
@{
    ViewData["Title"] = "Quản lý Danh mục Câu hỏi";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-2">
        <form method="get" class="d-flex" style="width: 300px;">
            <div class="input-group input-group-sm">
                <input type="search"
                       name="query"
                       value="@Model.query"
                       class="form-control"
                       placeholder="Tìm kiếm danh mục..."
                       aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit" title="Tìm kiếm">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
        </form>

        <a asp-page="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Tạo Danh mục mới
        </a>

        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm" title="Quay lại danh sách">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Danh sách Danh mục</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <quiz-table-head>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Tên Danh mục</th>
                        <th class="text-center" style="width: 50px;">ID</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </quiz-table-head>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model.CategoryList)
                    {
                        <tr class="align-middle">
                            <td class="text-center">@(stt++)</td>
                            <td>@item.CategoryName</td>
                            <td class="text-center">@item.CategoryID</td>
                            <td class="text-nowrap">
                                <div class="d-flex justify-content-center">
                                    <a asp-page="./Edit" asp-route-id="@item.CategoryID"
                                       class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                        <i class="fa-solid fa-pencil"></i>
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.CategoryID"
                                          class="form-delete">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.CategoryList.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center">Chưa có danh mục nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<div route-data="true"></div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const deleteForms = document.querySelectorAll('.form-delete');
            deleteForms.forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    var currentForm = this;

                    Swal.fire({
                        title: 'Bạn có chắc chắn?',
                        text: "Bạn muốn xóa danh mục này? Hành động này không thể hoàn tác!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Đồng ý!', 
                        cancelButtonText: 'Hủy'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            currentForm.submit();
                        }
                    });
                });
            });
        });

        
            const searchForm = document.querySelector("form[method='get']");
            const searchInput = searchForm?.querySelector("input[name='query']");
            if (searchForm) {
                searchForm.addEventListener("submit", function (e) {
                    if (!searchInput.value.trim()) {
                        e.preventDefault();
                        Swal.fire({
                            icon: "warning",
                            title: "Chưa nhập từ khóa!",
                            text: "Vui lòng nhập từ khóa để tìm kiếm.",
                            confirmButtonText: "OK"
                        });
                    }
                });
        }

        @if (TempData["NoResults"] != null)
        {
            <text>
                    Swal.fire({
                        icon: "info",
                    title: "Không có kết quả!",
                    text: "Không tìm thấy môn học phù hợp với từ khóa",
                    confirmButtonText: "Đóng"
            </text>
        }
    </script>
}