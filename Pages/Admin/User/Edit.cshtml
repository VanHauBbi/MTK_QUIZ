@page "{id}"
@model DALTWNC_QUIZ.Pages.Admin.User.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa User";
}

<div class="pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Thông tin User</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="UserToEdit.Username" />
                    <input type="hidden" asp-for="UserToEdit.Password" />

                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập</label>
                        <input class="form-control" value="@Model.UserToEdit.Username" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserToEdit.UserRole" class="form-label">Quyền truy cập</label>
                        <select asp-for="UserToEdit.UserRole" class="form-select">
                            <option value="C">Customer</option>
                            <option value="A">Admin</option>
                        </select>
                        <span asp-validation-for="UserToEdit.UserRole" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" asp-for="UserToEdit.IsLocked">
                        <label class="form-check-label" asp-for="UserToEdit.IsLocked">
                            Khóa tài khoản này
                        </label>
                        <span asp-validation-for="UserToEdit.IsLocked" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    <a asp-page="./Index" class="btn btn-secondary">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>
