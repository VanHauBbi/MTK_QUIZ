@page
@model DALTWNC_QUIZ.Pages.Admin.User.IndexModel
@{
    ViewData["Title"] = "Quản lý User";
}

<div class="pt-3 pb-2 mb-3 border-bottom d-flex justify-content-between align-items-center">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-2">
        <form method="get" class="d-flex" style="width: 300px;">
            <div class="input-group input-group-sm">
                <input type="search"
                       name="query"
                       value="@Model.query"
                       class="form-control"
                       placeholder="Tìm kiếm người dùng..."
                       aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
        </form>
        <a href="javascript:void(0);" onclick="history.back();" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Danh sách người dùng</h5>
    </div>

    <div class="card-body">
        <table class="table table-striped table-hover align-middle">
            <quiz-table-head>
                <tr>
                    <th>Họ và tên</th>
                    <th>Tên đăng nhập</th>
                    <th>Số điện thoại</th>
                    <th>Quyền</th>
                    <th>Trạng thái</th>
                    <th class="text-center" style="width: 150px;">Thao tác</th>
                </tr>
            </quiz-table-head>
            <tbody>
                @foreach (var item in Model.UserList)
                {
                    <tr is-active="!item.User.IsLocked">
                        <td>@(item.Customer?.CustomerName ?? "---")</td>
                        <td class="fw-bold">@item.User.Username</td>
                        <td>@(item.Customer?.CustomerPhone ?? "---")</td>
                        <td>
                            @if (item.User.UserRole == "A")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Customer</span>
                            }
                        </td>
                        <td>
                            @if (item.User.IsLocked)
                            {
                                <span class="badge bg-warning text-dark">Bị khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>

                        <td>
                            <div class="d-flex justify-content-center">
                                <a asp-page="./Edit" asp-route-id="@item.User.Username" class="btn btn-sm btn-outline-primary me-1" title="Sửa quyền & trạng thái">
                                    <i class="fa-solid fa-user-shield"></i>
                                </a>

                                @if (item.Customer != null)
                                {
                                    <a asp-page="./Details" asp-route-id="@item.Customer.CustomerID" class="btn btn-sm btn-outline-info me-1" title="Xem chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="btn btn-sm btn-outline-info me-1 disabled" title="Không có chi tiết Customer">
                                        <i class="fa-solid fa-eye"></i>
                                    </span>
                                }

                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.User.Username"
                                      class="form-delete">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div route-data="true"></div>

@section Scripts {
    <script>
        function showValidationToast(icon, message) {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: icon,
                title: message,
                showConfirmButton: false,
                timer: 4500,
                timerProgressBar: true
            });
        }

        document.addEventListener("DOMContentLoaded", function () {

            const deleteForms = document.querySelectorAll('.form-delete');
            deleteForms.forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    var currentForm = this;
                    Swal.fire({
                        title: 'Bạn có chắc chắn?',
                        text: "Bạn muốn xóa người dùng này? Hành động này không thể hoàn tác!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Đồng ý!',
                        cancelButtonText: 'Hủy'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            currentForm.submit();
                        }
                    });
                });
            });

            const searchForm = document.querySelector("form[method='get']");
            const searchInput = searchForm?.querySelector("input[name='query']");
            if (searchForm) {
                searchForm.addEventListener("submit", function (e) {
                    if (!searchInput.value.trim()) {
                        e.preventDefault();
                        Swal.fire({
                            icon: "warning",
                            title: "Chưa nhập từ khóa!",
                            text: "Vui lòng nhập từ khóa để tìm kiếm.",
                            confirmButtonText: "OK"
                        });
                    }
                });
            }

        @if (TempData["NoResults"] != null)
        {
            <text>
                Swal.fire({
                    icon: "info",
                title: "Không có kết quả!",
                text: "Không tìm thấy người dùng phù hợp với từ khóa",
                confirmButtonText: "Đóng"
                        });
            </text>
        }
                });
    </script>
}
