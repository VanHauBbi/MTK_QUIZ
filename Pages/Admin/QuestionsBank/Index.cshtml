@page
@model DALTWNC_QUIZ.Pages.Admin.QuestionsBank.IndexModel
@using DALTWNC_QUIZ.Models
@{
    ViewData["Title"] = "Ngân hàng Câu hỏi";
    ViewData["ActivePage"] = "QuestionsBank";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@ViewData["Title"]</h1>
    <div class="d-flex align-items-center gap-3">
        <form method="get" class="me-3">
            <select name="SubjectFilterId" asp-for="SubjectFilterId" asp-items="Model.SubjectSL" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="0">-- Lọc theo Môn học --</option>
            </select>
        </form>
        <form method="get" class="d-flex" style="width: 300px;">
            <div class="input-group input-group-sm">
                <input type="search"
                       name="query"
                       value="@Model.query"
                       class="form-control"
                       placeholder="Tìm kiếm câu hỏi..."
                       aria-label="Search" />
                <button class="btn btn-outline-primary" type="submit" title="Tìm kiếm">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>
        </form>

        <a asp-page="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Tạo Câu hỏi mới
        </a>

        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm" title="Quay lại danh sách">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

</div>

<div class="card shadow-sm mb-4">
    <div class="card-header"><h5 class="mb-0">Danh sách Câu hỏi</h5></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <quiz-table-head>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th style="width: 40%;">Nội dung Câu hỏi</th>
                        <th>Môn học</th>
                        <th>Danh mục</th>
                        <th class="text-center" style="width: 80px;">Đáp án</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </quiz-table-head>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in Model.QuestionList)
                    {
                        <tr class="align-middle">
                            <td class="text-center">@(stt++)</td>
                            <td>
                                @{
                                    var qText = item.QuestionText.Length > 120 ? item.QuestionText.Substring(0, 117) + "..." : item.QuestionText;
                                }
                                @Html.Raw(qText)
                            </td>
                            <td>@(item.Subject?.SubjectName ?? "N/A")</td>
                            <td>@(item.QuestionCategory?.CategoryName ?? "N/A")</td>
                            <td class="text-center">
                                @{
                                    var correctChoice = item.Choices?.FirstOrDefault(c => c.IsCorrect);
                                    if (correctChoice != null)
                                    {
                                        var choicesList = item.Choices.ToList();
                                        int correctIndex = choicesList.IndexOf(correctChoice);

                                        char correctLetter = (char)('A' + correctIndex);

                                        <span class="badge bg-success" style="font-size: 1em;">@correctLetter</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Không</span>
                                    }
                                }
                            </td>

                            <td class="text-nowrap">
                                <div class="d-flex justify-content-center">
                                    <a asp-page="Edit" asp-route-id="@item.QuestionID"
                                       class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                        <i class="fa-solid fa-pencil"></i>
                                    </a>

                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.QuestionID"
                                          asp-route-query="@Model.query" asp-route-subjectFilterId="@Model.SubjectFilterId"
                                          class="form-delete">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    
                </tbody>
            </table>
            @if (!Model.QuestionList.Any())
            {
                <div class="alert alert-warning text-center mt-3" role="alert">
                    @if (!string.IsNullOrEmpty(Model.query) || Model.SubjectFilterId != 0)
                    {
                        <p>
                            <strong>Không tìm thấy câu hỏi nào</strong>
                            khớp với bộ lọc hoặc từ khóa.
                        </p>
                    }
                    else
                    {
                        <p>Chưa có câu hỏi nào trong ngân hàng.</p>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div route-data="true">
</div>

@section Scripts {
    <script>
        const searchForm = document.querySelector("form[method='get']");
        const searchInput = searchForm?.querySelector("input[name='query']");
        if (searchForm) {
            searchForm.addEventListener("submit", function (e) {
                if (!searchInput.value.trim()) {
                    e.preventDefault();
                    Swal.fire({
                        icon: "warning",
                        title: "Chưa nhập từ khóa!",
                        text: "Vui lòng nhập từ khóa để tìm kiếm.",
                        confirmButtonText: "OK"
                    });
                }
            });
        }

        @if (TempData["NoResults"] != null)
        {
            <text>
                    Swal.fire({ icon: "info",
                    title: "Không có kết quả!",
                    text: "Không tìm thấy môn học phù hợp với từ khóa",
                    confirmButtonText: "Đóng"
            </text>
        }
    </script>
}